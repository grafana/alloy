#!/usr/bin/env sh
if [ -f "/opt/homebrew/etc/alloy/config.env" ]; then
  set -a
  . "/opt/homebrew/etc/alloy/config.env"
  set +a
fi

# Run in OTel mode when ALLOY_OTEL_MODE is truthy. The `otel` subcommand has
# different flags than `run`: it takes a `--config` file URL, does not support
# `--storage.path`, and reads its own extra-args file.
otel_mode=""
case "${ALLOY_OTEL_MODE:-}" in
  1 | true | yes | on ) otel_mode="1" ;;
esac

extra_args_file="/opt/homebrew/etc/alloy/extra-args.txt"
[ -n "$otel_mode" ] && extra_args_file="/opt/homebrew/etc/alloy/otel-extra-args.txt"

extra_args=""
[ -f "$extra_args_file" ] && extra_args=$(cat "$extra_args_file")

if [ -n "$otel_mode" ]; then
  exec "/opt/homebrew/opt/alloy/bin/alloy" otel \
    --config="file:/opt/homebrew/etc/alloy/config.alloy/config.yaml" \
    $extra_args
else
  exec "/opt/homebrew/opt/alloy/bin/alloy" run \
    --storage.path="/opt/homebrew/var/lib/alloy/data" \
    $extra_args \
    "/opt/homebrew/etc/alloy/config.alloy"
fi
