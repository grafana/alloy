{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "changelog-sections": [
    { "type": "feat", "section": "Features 🌟" },
    { "type": "fix", "section": "Bug Fixes 🐛" },
    { "type": "docs", "section": "Documentation", "hidden": true },
    { "type": "style", "section": "Styles", "hidden": true },
    { "type": "refactor", "section": "Refactoring", "hidden": true },
    { "type": "perf", "section": "Performance", "hidden": true },
    { "type": "test", "section": "Tests", "hidden": true },
    { "type": "ci", "section": "CI", "hidden": true },
    { "type": "chore", "section": "Chores", "hidden": true },
    { "type": "proposal", "section": "Proposals", "hidden": true },
    { "type": "revert", "section": "Reverts", "hidden": true }
  ],
  "always-update": true,
  "draft": true,
  "tag-separator": "/",
  "force-tag-creation": true,
  "draft-pull-request": true,
  "separate-pull-requests": false,
  "group-pull-request-title-pattern": "chore${scope}: Release ${version}",
  "pull-request-title-pattern": "chore${scope}: Release${component} ${version}",
  "packages": {
    ".": {
      "release-type": "go",
      "versioning": "minor-breaking",
      "changelog-path": "CHANGELOG.md",
      "exclude-paths": [
        "syntax"
      ],
      "extra-files": [
        {
          "type": "generic",
          "path": "docs/sources/_index.md"
        },
        {
          "type": "generic",
          "path": "collector/builder-config.yaml"
        },
        {
          "type": "generic",
          "path": "collector/VERSION"
        }
      ]
    },
    "syntax": {
      "package-name": "syntax",
      "release-type": "go",
      "versioning": "minor-breaking",
      "changelog-path": "CHANGELOG.md",
      "skip-github-release": true,
      "extra-files": [
        {
          "type": "generic",
          "path": "/go.mod"
        }
      ]
    }
  }
}
