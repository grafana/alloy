logging {
  level = "debug"
}

livedebugging {
  enabled = true
}

loki.source.podlogs "pods" {
  forward_to = [loki.process.tag.receiver]
}

loki.process "tag" {
  forward_to = [loki.write.loki.receiver]

  stage.structured_metadata {
    values = {
      pod = "",
    }
  }
}

loki.write "loki" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }

  external_labels = {
      alloy_test_name = "loki-source-podlogs",
  }
}
