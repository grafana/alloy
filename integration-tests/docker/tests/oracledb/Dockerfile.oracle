# syntax=docker/dockerfile:1
# Layers Oracle Instant Client (ZIP) on the standard Alloy image from the repo root Dockerfile.
# Matches Oracle’s ZIP install flow: unzip under /opt/oracle, libaio, ld.so.conf.d + ldconfig:
# https://www.oracle.com/database/technologies/instant-client/linux-x86-64-downloads.html
#
# Layered on alloy-integration-tests. Built via tests/oracledb/test.yaml (alloy_container.dockerfile).
#   make ALLOY_IMAGE=alloy-integration-tests alloy-image
#   docker build --platform=linux/amd64 -f integration-tests/docker/tests/oracledb/Dockerfile.oracle -t alloy-integration-tests-oracledb:latest .

FROM --platform=linux/amd64 alloy-integration-tests:latest

USER root

RUN apt-get update \
	&& apt-get install -y --no-install-recommends ca-certificates wget unzip libaio1t64 \
	&& rm -rf /var/lib/apt/lists/* \
	&& LIBDIR="/usr/lib/$(uname -m)-linux-gnu" \
	&& if [ -f "${LIBDIR}/libaio.so.1t64" ] && [ ! -e "${LIBDIR}/libaio.so.1" ]; then \
		ln -sf libaio.so.1t64 "${LIBDIR}/libaio.so.1"; \
	fi

WORKDIR /opt/oracle

# Basic package is required; override with --build-arg ORACLE_IC_ZIP_URL=... if Oracle moves the artifact.
ARG ORACLE_IC_ZIP_URL=https://download.oracle.com/otn_software/linux/instantclient/2326100/instantclient-basic-linux.x64-23.26.1.0.0.zip

RUN wget -q --progress=dot:giga --no-check-certificate \
		--header "Cookie: oraclelicense=accept-securebackup-cookie" \
		-O /tmp/instantclient-basic.zip \
		"${ORACLE_IC_ZIP_URL}" \
	&& unzip -q /tmp/instantclient-basic.zip -d /opt/oracle \
	&& rm -f /tmp/instantclient-basic.zip \
	&& INST_DIR="$(ls -d /opt/oracle/instantclient_* | head -1)" \
	&& mkdir -p "${INST_DIR}/network/admin" \
	&& printf '%s\n' "${INST_DIR}" > /etc/ld.so.conf.d/oracle-instantclient.conf \
	&& ldconfig \
	&& chmod -R a+rX /opt/oracle
