loki.source.file "test" {
	targets = [
		{__path__ = "/etc/alloy/mount/cri.log", format = "cri"},
		{__path__ = "/etc/alloy/mount/docker.log", format = "docker"},
		{__path__ = "/etc/alloy/mount/json.log", format = "json"},
		{__path__ = "/etc/alloy/mount/logfmt.log", format = "logfmt"},
		{__path__ = "/etc/alloy/mount/multiline.log", format = "multiline"},
		{__path__ = "/etc/alloy/mount/nginx.log", format = "nginx"},
	]

	file_match {
		enabled = true
	}

	forward_to = [loki.process.p.receiver]
}

loki.process "p" {
	forward_to = [loki.write.test.receiver]

	stage.match {
		selector = `{format="cri"}`

		stage.cri { }
	}

	stage.match {
		selector = `{format="docker"}`

		stage.docker { }
	}

	stage.match {
		selector = `{format="json"}`

		stage.json {
			expressions = {msg = "msg", service_name = "service_name"}
		}

		stage.output {
			source = "msg"
		}
	}

	stage.match {
		selector = `{format="logfmt"}`

		stage.logfmt {
			mapping = {msg = "msg", service_name = "service_name"}
		}

		stage.output {
			source = "msg"
		}
	}

	stage.match {
		selector = `{format="multiline"}`

		stage.multiline {
			firstline     = `^\[\d{4}-\d{2}-\d{2} \d{1,2}:\d{2}:\d{2}\]`
			max_wait_time = "1s"
		}

		stage.regex {
			expression = `^\[(?P<time>\d{4}-\d{2}-\d{2} \d{1,2}:\d{2}:\d{2})\] (?P<msg>(?s:.*))$`
		}

		stage.timestamp {
			source = "time"
			format = "2006-01-02 15:04:05"
		}

		stage.match {
			selector = `{format="multiline"} |= "Exception on"`

			stage.regex {
				source     = "msg"
				expression = `^ERROR in app: Exception on (?P<route>\S+) \[(?P<method>\S+)\](?s:.*)$`
			}
		}

		stage.match {
			selector = `{format="multiline"} != "Exception on"`

			stage.regex {
				source     = "msg"
				expression = `^"(?P<method>\S+) (?P<route>\S+) \S+" \d+ -(?s:.*)$`
			}
		}

		stage.labels {
			values = {
				method = "",
				route  = "",
			}
		}

		stage.output {
			source = "msg"
		}
	}

	stage.match {
		selector = `{format="nginx"}`

		stage.pattern {
			pattern = `<_> - - [<time>] "<method> <_> <_>" <status> <_> "<_>" "<_>"`
		}

		stage.timestamp {
			source = "time"
			format = "02/Jan/2006:15:04:05 -0700"
		}

		stage.labels {
			values = {
				method = "",
				status = "",
			}
		}
	}

	stage.labels {
		values = {
			service_name = "",
		}
	}

	stage.structured_metadata {
		values = {
			filename = "",
		}
	}
}

loki.write "test" {
	endpoint {
		url = "http://loki:3100/loki/api/v1/push"
	}
	external_labels = {
		test_name = "processlogfile",
	}
}
