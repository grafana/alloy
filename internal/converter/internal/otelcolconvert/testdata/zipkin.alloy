otelcol.receiver.zipkin "default" {
	endpoint            = "localhost:9411"
	idle_timeout        = "0s"
	write_timeout       = "0s"
	read_header_timeout = "0s"

	output {
		traces = [otelcol.exporter.otlp.default.input]
	}
}

otelcol.exporter.otlp "default" {
	client {
		endpoint = "database:4317"
	}
}
