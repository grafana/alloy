otelcol.receiver.otlp "default" {
	grpc {
		endpoint = "127.0.0.1:4317"
	}

	http {
		endpoint = "127.0.0.1:4318"
	}

	output {
		logs   = [otelcol.connector.signaltometrics.default.input]
		traces = [otelcol.connector.signaltometrics.default.input]
	}
}

otelcol.exporter.otlp "default" {
	client {
		endpoint = "localhost:4317"

		tls {
			insecure = true
		}
	}
}

otelcol.connector.signaltometrics "default" {
	spans {
		name        = "span.duration"
		description = "Span duration histogram"
		unit        = "ms"

		histogram {
			buckets = [2, 4, 6, 8, 10, 50, 100, 200, 400, 800, 1000, 1400, 2000, 5000, 10000, 15000]
			value   = "Milliseconds(end_time - start_time)"
		}
	}

	logs {
		name        = "log.body.length"
		description = "Distribution of log body lengths"

		attributes {
			key           = "severity_text"
			default_value = "INFO"
		}
		conditions = ["severity_number >= SEVERITY_NUMBER_WARN"]

		exponential_histogram {
			max_size = 160
			value    = "Len(body)"
		}
	}
	error_mode = "ignore"

	output {
		metrics = [otelcol.exporter.otlp.default.input]
	}
}
