{
  "name": "@grafana/alloy-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.16.0",
    "npm": ">=11.13.0"
  },
  "scripts": {
    "dev": "vite",
    "generate:fixtures": "tsx src/test/fixtures/writeFixture.ts",
    "dev:mock": "npm run generate:fixtures && MOCK=true vite",
    "build": "tsc -b && vite build",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.6",
    "@grafana/alloy-pipeline-graph": "^0.2.0",
    "normalize.css": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.16.0"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.9.1",
    "@types/react": "18.3.29",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "5.2.0",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "globals": "16.5.0",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "tsx": "4.22.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.0",
    "vite": "7.3.5",
    "vitest": "4.1.7"
  }
}
