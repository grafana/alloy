#!/usr/bin/env bash

# shellcheck disable=SC2154  # $usage_* vars are injected by mise from #USAGE

#MISE hide=true
#USAGE flag "-r --release" help="Strip symbol table and DWARF for a smaller release binary" default="false"
#USAGE flag "-t --tags <tags>" help="Comma-separated extra build tags (e.g. netgo,embedalloyui)" default=""
#USAGE flag "-o --output <path>" help="Output binary path (relative to repo root, or absolute)" default="build/alloy"

set -euo pipefail

ldflags="$(mise run -q _build:ldflags)"
if [ "$usage_release" = "true" ]; then
  ldflags="-s -w ${ldflags}"
fi

tags="gore2regex"
if [ -n "${usage_tags:-}" ]; then
  tags="${tags},${usage_tags}"
fi

go build -C collector -tags "$tags" -ldflags "$ldflags" -o "$usage_output" .
