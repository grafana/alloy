#!/usr/bin/env bash

set -euo pipefail

dirs=(
  docs
  scripts
  packaging
  .github
)

files=()
while IFS= read -r -d '' f; do
  if head -1 "$f" 2>/dev/null | grep -qE '^#!.*[/ ](sh|bash)$'; then
    files+=("$f")
  fi
done < <(find "${dirs[@]}" -type f \( -iname '*.sh' -o -iname '*.bash' -o ! -iname '*.*' \) -print0)

if [ ${#files[@]} -eq 0 ]; then
  echo "==> shellcheck: no files to check"
  exit 0
fi

echo "==> shellcheck: ${#files[@]} files"
shellcheck "${files[@]}"
